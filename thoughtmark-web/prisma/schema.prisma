// prisma/schema.prisma
// Thoughtmark 数据模型 — Prisma 是数据库唯一真相来源
// 所有 schema 变更必须通过 prisma migrate，禁止手动改数据库

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Story 1.1: 初始 User model
// Story 2.1: 添加 passwordHash
// Story 2.2: 添加 accounts/sessions 关系（NextAuth OAuth）
// Story 3.1: 添加 bookmarks 关系
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?    @map("password_hash")
  createdAt    DateTime   @default(now()) @map("created_at")
  bookmarks    Bookmark[]
  accounts     Account[]
  sessions     Session[]

  @@map("users")
}

// Story 2.2: NextAuth PrismaAdapter — OAuth 账户关联
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Story 2.2: NextAuth Session（数据库策略用）
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Story 2.2: 邮箱验证 token（预留）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Story 3.1: 书签核心 model
// whySaved 是产品核心字段 — "为什么收藏这个"
model Bookmark {
  id        String   @id @default(cuid())
  url       String
  title     String
  whySaved  String?  @map("why_saved")
  quickTags String[] @map("quick_tags")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("bookmarks")
}
